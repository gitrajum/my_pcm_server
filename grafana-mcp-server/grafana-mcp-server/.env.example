# Environment Configuration for GrafanaMcpServer

# Server Configuration
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Azure AD Authentication
# Required for production deployment - validates tokens from A2A agents
MCP_AUTH_ENABLED=true
AZURE_TENANT_ID=fcb2b37b-5da0-466b-9b83-0014b67a7c78
MANAGED_IDENTITY_CLIENT_ID=906f830e-eeab-46e1-9e90-ad410c8649a3

# Note: Set MCP_AUTH_ENABLED=false to disable auth for local development

# Telemetry (Optional)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=grafana-mcp-server
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Grafana/Mimir Configuration
GRAFANA_BASE_URL=https://prometheus-dedicated-64-prod-eu-west-5.grafana.net
GRAFANA_TENANT_ID=66c294a8-edad-46aa-aa10-644e435b6ec3
GRAFANA_USER=2834315
GRAFANA_TOKEN=your_grafana_api_token_here
GRAFANA_TIMEOUT=30
